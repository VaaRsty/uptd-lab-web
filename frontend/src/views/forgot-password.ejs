<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lupa Password - UPTD Laboratorium Pengujian Banten</title>
    <meta name="description" content="Reset password akun UPTD Laboratorium Pengujian Banten Anda dengan mudah.">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/auth.css">

    <script src="/config.js"></script>
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>
</head>
<body>
    <div class="auth-container">
        <!-- ── Bagian Kiri (Form) ── -->
        <div class="auth-form-container">
            <div class="auth-form-content">

                <a href="/" class="back-link">
                    <i class="fas fa-arrow-left"></i> Kembali ke Beranda
                </a>

                <!-- Logo -->
                <div class="auth-logo">
                    <img src="/img/logo-banten.png" alt="Logo UPTD" onerror="this.style.display='none'">
                    <div>
                        <div class="auth-logo-text">UPTD Laboratorium</div>
                        <div class="auth-logo-sub">Pengujian Banten</div>
                    </div>
                </div>

                <!-- ── FORM STATE ── -->
                <div id="formState">
                    <div class="auth-header">
                        <h2>Lupa Password?</h2>
                        <p>Masukkan email yang terdaftar, kami akan mengirimkan tautan untuk reset password Anda.</p>
                    </div>

                    <!-- Alert message -->
                    <div id="alertMessage" class="alert" style="display: none;" role="alert">
                        <span class="alert-icon" id="alertIcon"></span>
                        <span id="alertText"></span>
                    </div>

                    <form id="forgotPasswordForm" class="auth-form" novalidate>
                        <div class="form-group">
                            <label for="email">Alamat Email</label>
                            <div class="input-group">
                                <span class="input-icon"><i class="far fa-envelope"></i></span>
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    class="form-control"
                                    placeholder="contoh@email.com"
                                    autocomplete="email"
                                    required
                                >
                            </div>
                            <span class="field-error" id="emailError"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-block" id="btnSubmit">
                            <i class="fas fa-paper-plane"></i>
                            Kirim Link Reset Password
                        </button>
                    </form>

                    <div class="auth-footer text-center mt-4">
                        <p>Ingat password Anda? <a href="/login">Login di sini</a></p>
                    </div>
                </div>

                <!-- ── SUCCESS STATE ── -->
                <div class="success-state" id="successState">
                    <div class="success-icon-wrapper">
                        <i class="fas fa-envelope-open-text"></i>
                    </div>
                    <h3>Email Terkirim!</h3>
                    <p>
                        Kami telah mengirimkan instruksi reset password ke<br>
                        <span class="highlight-email" id="sentEmailDisplay"></span>
                    </p>

                    <div class="success-steps">
                        <p>Langkah selanjutnya:</p>
                        <div class="step-item">
                            <span class="step-num">1</span>
                            <span>Buka inbox email Anda (cek juga folder <strong>Spam/Junk</strong>)</span>
                        </div>
                        <div class="step-item">
                            <span class="step-num">2</span>
                            <span>Klik link <strong>"Reset Password"</strong> di dalam email</span>
                        </div>
                        <div class="step-item">
                            <span class="step-num">3</span>
                            <span>Buat password baru yang kuat dan aman</span>
                        </div>
                    </div>

                    <p style="font-size:0.8rem; color: var(--gray-light); margin-bottom:20px;">
                        Link berlaku selama <strong>1 jam</strong>. Belum menerima email?
                    </p>

                    <button class="btn btn-primary btn-block" id="btnResend" onclick="showFormAgain()">
                        <i class="fas fa-redo"></i> Kirim Ulang Email
                    </button>

                    <div class="auth-footer text-center mt-4">
                        <p><a href="/login"><i class="fas fa-arrow-left"></i> Kembali ke Login</a></p>
                    </div>
                </div>

            </div>
        </div>

        <!-- ── Bagian Kanan (Branding) ── -->
        <div class="auth-branding">
            <div class="branding-circle"></div>
            <div class="branding-circle"></div>
            <div class="branding-overlay"></div>
            <div class="branding-content">
                <img src="/img/logo-banten.png" alt="Logo Banten">
                <h1>Sistem Informasi<br>Pelayanan Publik</h1>
                <p>UPTD Pengujian Bahan Konstruksi Bangunan dan Informasi Konstruksi Dinas Pekerjaan Umum dan Penataan Ruang Provinsi Banten</p>
            </div>
        </div>
    </div>

    <script>
        const form       = document.getElementById('forgotPasswordForm');
        const btnSubmit  = document.getElementById('btnSubmit');
        const alertBox   = document.getElementById('alertMessage');
        const alertIcon  = document.getElementById('alertIcon');
        const alertText  = document.getElementById('alertText');
        const emailInput = document.getElementById('email');
        const emailError = document.getElementById('emailError');

        // ── Tampilkan alert ───────────────────────────────────────────────
        function showAlert(type, iconClass, message) {
            alertBox.className = 'alert alert-' + type;
            alertIcon.className = 'alert-icon ' + iconClass;
            alertText.textContent = message;
            alertBox.style.display = 'flex';
        }

        // ── Validasi email ─────────────────────────────────────────────────
        function validateEmail(value) {
            const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!value) {
                showFieldError(emailInput, emailError, 'Email tidak boleh kosong.');
                return false;
            }
            if (!re.test(value)) {
                showFieldError(emailInput, emailError, 'Format email tidak valid.');
                return false;
            }
            clearFieldError(emailInput, emailError);
            return true;
        }

        function showFieldError(input, errorEl, msg) {
            input.classList.add('is-invalid');
            errorEl.textContent = msg;
            errorEl.classList.add('show');
        }

        function clearFieldError(input, errorEl) {
            input.classList.remove('is-invalid');
            errorEl.classList.remove('show');
        }

        // Live validation
        emailInput.addEventListener('input', () => {
            if (emailInput.classList.contains('is-invalid')) {
                validateEmail(emailInput.value.trim());
            }
        });

        // ── Submit form ────────────────────────────────────────────────────
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const email = emailInput.value.trim();
            if (!validateEmail(email)) return;

            // Loading state
            btnSubmit.disabled = true;
            btnSubmit.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Mengirim...';
            alertBox.style.display = 'none';

            try {
                const backendUrl = (window.APP_CONFIG?.backendUrl || 'http://localhost:5000');
                const response = await fetch(backendUrl + '/api/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });

                const data = await response.json();

                if (data.success) {
                    // Tampilkan success state
                    document.getElementById('formState').style.display = 'none';
                    const successState = document.getElementById('successState');
                    successState.style.display = 'block';
                    document.getElementById('sentEmailDisplay').textContent = email;
                } else {
                    showAlert('danger', 'fas fa-exclamation-circle', data.message || 'Terjadi kesalahan. Silakan coba lagi.');
                    btnSubmit.disabled = false;
                    btnSubmit.innerHTML = '<i class="fas fa-paper-plane"></i> Kirim Link Reset Password';
                }
            } catch (err) {
                showAlert('danger', 'fas fa-wifi', 'Gagal terhubung ke server. Periksa koneksi internet Anda.');
                btnSubmit.disabled = false;
                btnSubmit.innerHTML = '<i class="fas fa-paper-plane"></i> Kirim Link Reset Password';
            }
        });

        // ── Kirim ulang ────────────────────────────────────────────────────
        function showFormAgain() {
            document.getElementById('successState').style.display = 'none';
            document.getElementById('formState').style.display = 'block';
            btnSubmit.disabled = false;
            btnSubmit.innerHTML = '<i class="fas fa-paper-plane"></i> Kirim Link Reset Password';
            alertBox.style.display = 'none';
            emailInput.value = '';
        }
    </script>
</body>
</html>
