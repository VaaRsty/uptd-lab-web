<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lupa Password - UPTD Pengujian</title>
    <link rel="icon" type="image/png" href="/img/logo.png">
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/config.js"></script>
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>

    <style>
        /* ── Komponen tambahan khusus halaman forgot-password ── */
        .back-link-container {
            display: flex;
            justify-content: flex-start;
            margin-bottom: 15px;
            width: 100%;
        }
        .back-to-login {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--primary);
            text-decoration: none;
            transition: gap 0.2s;
        }
        .back-to-login:hover { gap: 10px; }

        .fp-desc {
            font-size: 0.875rem;
            color: var(--secondary);
            margin-bottom: 20px;
            line-height: 1.6;
        }

        /* Alert box */
        .alert-box {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 12px 14px;
            border-radius: 10px;
            font-size: 0.85rem;
            font-weight: 500;
            margin-bottom: 16px;
            animation: fadeSlideIn 0.3s ease;
            text-align: left;
        }
        .alert-error   { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
        .alert-success { background: #d1fae5; color: #065f46; border: 1px solid #a7f3d0; }
        .alert-box i   { margin-top: 1px; flex-shrink: 0; }

        @keyframes fadeSlideIn {
            from { opacity: 0; transform: translateY(-6px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Field error */
        .field-error-msg {
            font-size: 0.78rem;
            color: #dc2626;
            margin-top: 4px;
            margin-left: 2px;
            display: none;
        }
        .field-error-msg.show { display: block; animation: fadeSlideIn 0.2s ease; }
        .form-input.is-invalid { border-color: #f87171 !important; }
        .form-input.is-invalid:focus { box-shadow: 0 0 0 3px rgba(248, 113, 113, 0.15) !important; }

        /* Success state */
        .success-state { display: none; animation: fadeSlideIn 0.4s ease; }
        .success-icon {
            width: 72px; height: 72px;
            border-radius: 50%;
            background: #d1fae5;
            color: var(--primary);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.8rem;
            margin: 0 auto 18px;
            box-shadow: 0 0 0 8px rgba(209, 250, 229, 0.5);
        }
        .success-title { font-size: 1.25rem; font-weight: 700; color: var(--dark); margin-bottom: 8px; }
        .success-desc  { font-size: 0.875rem; color: var(--secondary); line-height: 1.6; margin-bottom: 18px; }
        .email-badge {
            display: inline-block;
            background: #d1fae5; color: #065f46;
            padding: 2px 10px; border-radius: 6px;
            font-weight: 600; font-size: 0.875rem;
        }
        .steps-guide {
            background: #f8fafc;
            border-radius: 10px;
            padding: 14px 16px;
            text-align: left;
            margin-bottom: 18px;
        }
        .steps-guide-label {
            font-size: 0.7rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.07em;
            color: #94a3b8; margin-bottom: 12px;
        }
        .step-row {
            display: flex; gap: 10px; align-items: flex-start;
            font-size: 0.85rem; color: var(--dark);
            margin-bottom: 8px; line-height: 1.5;
        }
        .step-row:last-child { margin-bottom: 0; }
        .step-badge {
            width: 22px; height: 22px; border-radius: 50%;
            background: var(--primary); color: #fff;
            font-size: 0.7rem; font-weight: 700;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .expire-note {
            font-size: 0.78rem; color: #94a3b8; margin-bottom: 18px;
        }

        /* Responsive */
        @media (max-width: 480px) {
            .login-body { padding: 16px; align-items: flex-start; padding-top: 40px; }
            .login-card { padding: 28px 18px; }
        }
    </style>
</head>
<body class="login-body">

    <div class="login-card" style="max-width: 440px;">

        <!-- Back link -->
        <div class="back-link-container">
            <a href="/login" class="back-to-login">
                <i class="fas fa-arrow-left"></i> Kembali ke Login
            </a>
        </div>

        <!-- Header (konsisten dengan login/register) -->
        <div class="auth-icon-wrapper">
            <img src="/img/logo-banten.png" alt="Logo Banten" style="width: 100%; height: auto;">
        </div>
        <h2 class="auth-title">UPTD Pengujian</h2>
        <p class="auth-subtitle">Bahan Konstruksi Bangunan &amp; Informasi Konstruksi</p>

        <!-- ── FORM STATE ── -->
        <div id="formState">
            <h3 style="font-size:1.05rem; font-weight:700; color:var(--dark); margin-bottom:6px; text-align:left;">Lupa Password?</h3>
            <p class="fp-desc">Masukkan email yang terdaftar. Kami akan mengirimkan tautan untuk reset password Anda.</p>

            <!-- Alert container -->
            <div id="alertContainer"></div>

            <form id="forgotPasswordForm" novalidate>
                <div class="form-group">
                    <label class="form-label" for="email">Alamat Email</label>
                    <div class="input-wrapper">
                        <i class="fas fa-envelope icon-start"></i>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            class="form-input"
                            placeholder="nama@instansi.com"
                            autocomplete="email"
                            required
                        >
                    </div>
                    <span class="field-error-msg" id="emailError"></span>
                </div>

                <button type="submit" class="btn-auth-base btn-action-login btn-full" id="btnSubmit">
                    <span class="button-text"><i class="fas fa-paper-plane" style="margin-right:6px;"></i>Kirim Link Reset</span>
                    <span class="button-loader" style="display:none;"><i class="fas fa-spinner fa-spin"></i> Mengirim...</span>
                </button>
            </form>

            <div class="auth-footer" style="text-align:center; margin-top:16px;">
                Ingat password? <a href="/login" style="color:var(--primary); font-weight:600;">Login di sini</a>
            </div>
        </div>

        <!-- ── SUCCESS STATE ── -->
        <div class="success-state" id="successState">
            <div class="success-icon">
                <i class="fas fa-envelope-open-text"></i>
            </div>
            <p class="success-title">Email Terkirim!</p>
            <p class="success-desc">
                Instruksi reset password dikirim ke<br>
                <span class="email-badge" id="sentEmailDisplay"></span>
            </p>

            <div class="steps-guide">
                <p class="steps-guide-label">Langkah selanjutnya</p>
                <div class="step-row">
                    <span class="step-badge">1</span>
                    <span>Buka inbox email Anda, cek folder <strong>Spam/Junk</strong> jika tidak ada</span>
                </div>
                <div class="step-row">
                    <span class="step-badge">2</span>
                    <span>Klik tombol <strong>"Reset Password"</strong> di dalam email</span>
                </div>
                <div class="step-row">
                    <span class="step-badge">3</span>
                    <span>Buat password baru yang kuat</span>
                </div>
            </div>

            <p class="expire-note">Link berlaku selama <strong>1 jam</strong>. Belum menerima?</p>

            <button class="btn-auth-base btn-action-login btn-full" onclick="showFormAgain()" style="margin-bottom:10px;">
                <i class="fas fa-redo" style="margin-right:6px;"></i>Kirim Ulang Email
            </button>
            <a href="/login" class="btn-auth-base btn-action-login btn-full" style="text-align:center; display:block;">
                <i class="fas fa-sign-in-alt" style="margin-right:6px;"></i>Kembali ke Login
            </a>
        </div>

        <!-- Footer -->
        <div class="auth-footer">
            © 2026 Pengujian Bahan Konstruksi Bangunan &amp; Informasi Konstruksi Provinsi Banten.
        </div>

    </div>

    <script>
        const emailInput  = document.getElementById('email');
        const emailError  = document.getElementById('emailError');
        const alertCont   = document.getElementById('alertContainer');

        // ── Show alert ─────────────────────────────────────────────────────
        function showAlert(type, iconClass, msg) {
            alertCont.innerHTML = `
                <div class="alert-box alert-${type}">
                    <i class="fas ${iconClass}"></i>
                    <span>${msg}</span>
                </div>`;
        }

        // ── Validate email ─────────────────────────────────────────────────
        function validateEmail(value) {
            const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!value) {
                emailError.textContent = 'Email tidak boleh kosong.';
                emailError.classList.add('show');
                emailInput.classList.add('is-invalid');
                return false;
            }
            if (!re.test(value)) {
                emailError.textContent = 'Format email tidak valid.';
                emailError.classList.add('show');
                emailInput.classList.add('is-invalid');
                return false;
            }
            emailError.classList.remove('show');
            emailInput.classList.remove('is-invalid');
            return true;
        }

        emailInput.addEventListener('input', () => {
            if (emailInput.classList.contains('is-invalid')) validateEmail(emailInput.value.trim());
        });

        // ── Submit ─────────────────────────────────────────────────────────
        document.getElementById('forgotPasswordForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = emailInput.value.trim();
            if (!validateEmail(email)) return;

            const btn      = document.getElementById('btnSubmit');
            const btnText  = btn.querySelector('.button-text');
            const btnLoad  = btn.querySelector('.button-loader');

            btnText.style.display = 'none';
            btnLoad.style.display = 'inline';
            btn.disabled = true;
            alertCont.innerHTML = '';

            try {
                const backendUrl = (window.APP_CONFIG?.backendUrl || 'http://localhost:5000');
                const res  = await fetch(backendUrl + '/api/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                const data = await res.json();

                if (data.success) {
                    document.getElementById('formState').style.display = 'none';
                    document.getElementById('sentEmailDisplay').textContent = email;
                    document.getElementById('successState').style.display = 'block';
                } else {
                    showAlert('error', 'fa-exclamation-circle', data.message || 'Terjadi kesalahan. Silakan coba lagi.');
                    btnText.style.display = 'inline';
                    btnLoad.style.display = 'none';
                    btn.disabled = false;
                }
            } catch (err) {
                showAlert('error', 'fa-wifi', 'Gagal terhubung ke server. Periksa koneksi internet Anda.');
                btnText.style.display = 'inline';
                btnLoad.style.display = 'none';
                btn.disabled = false;
            }
        });

        // ── Show form again ─────────────────────────────────────────────────
        function showFormAgain() {
            document.getElementById('successState').style.display = 'none';
            document.getElementById('formState').style.display = 'block';
            emailInput.value = '';
            alertCont.innerHTML = '';
            const btn = document.getElementById('btnSubmit');
            btn.disabled = false;
            btn.querySelector('.button-text').style.display = 'inline';
            btn.querySelector('.button-loader').style.display = 'none';
        }
    </script>

</body>
</html>
