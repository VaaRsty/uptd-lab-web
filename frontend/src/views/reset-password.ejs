<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - UPTD Pengujian</title>
    <link rel="icon" type="image/png" href="/img/logo.png">
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/config.js"></script>
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="/js/socket-listener.js"></script>

    <style>
        /* ── Komponen tambahan khusus halaman reset-password ── */
        .back-to-login {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--primary);
            text-decoration: none;
            margin-bottom: 18px;
            transition: gap 0.2s;
        }
        .back-to-login:hover { gap: 10px; }

        .fp-desc {
            font-size: 0.875rem;
            color: var(--secondary);
            margin-bottom: 20px;
            line-height: 1.6;
        }

        /* Alert box */
        .alert-box {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 12px 14px;
            border-radius: 10px;
            font-size: 0.85rem;
            font-weight: 500;
            margin-bottom: 16px;
            animation: fadeSlideIn 0.3s ease;
            text-align: left;
        }
        .alert-error   { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
        .alert-success { background: #d1fae5; color: #065f46; border: 1px solid #a7f3d0; }
        .alert-box i   { margin-top: 1px; flex-shrink: 0; }

        @keyframes fadeSlideIn {
            from { opacity: 0; transform: translateY(-6px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Field error */
        .field-error-msg {
            font-size: 0.78rem;
            color: #dc2626;
            margin-top: 4px;
            margin-left: 2px;
            display: none;
        }
        .field-error-msg.show { display: block; animation: fadeSlideIn 0.2s ease; }
        .form-input.is-invalid { border-color: #f87171 !important; }
        .form-input.is-invalid:focus { box-shadow: 0 0 0 3px rgba(248, 113, 113, 0.15) !important; }
        .form-input.is-valid { border-color: #34d399 !important; }
        .form-input.is-valid:focus { box-shadow: 0 0 0 3px rgba(52, 211, 153, 0.15) !important; }

        /* Password strength */
        .strength-wrap { margin-top: 8px; display: none; }
        .strength-bars { display: flex; gap: 4px; margin-bottom: 4px; }
        .strength-bars span {
            flex: 1; height: 4px; border-radius: 99px;
            background: #e2e8f0; transition: background 0.3s;
        }
        .s-weak   { background: #f87171 !important; }
        .s-medium { background: #fbbf24 !important; }
        .s-strong { background: #34d399 !important; }
        .strength-label { font-size: 0.75rem; color: #94a3b8; }
        .strength-label.weak   { color: #f87171; }
        .strength-label.medium { color: #f59e0b; }
        .strength-label.strong { color: #10b981; }

        /* Token error state */
        .token-error-state {
            display: none;
            text-align: center;
            padding: 10px 0;
            animation: fadeSlideIn 0.4s ease;
        }
        .error-icon-wrap {
            width: 70px; height: 70px; border-radius: 50%;
            background: #fee2e2; color: #dc2626;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.8rem; margin: 0 auto 16px;
        }
        .error-title { font-size: 1.1rem; font-weight: 700; color: var(--dark); margin-bottom: 8px; }
        .error-desc  { font-size: 0.875rem; color: var(--secondary); line-height: 1.6; margin-bottom: 18px; }

        /* Success state */
        .success-state { display: none; text-align: center; animation: fadeSlideIn 0.4s ease; }
        .success-icon {
            width: 72px; height: 72px; border-radius: 50%;
            background: #d1fae5; color: var(--primary);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.8rem; margin: 0 auto 18px;
            box-shadow: 0 0 0 8px rgba(209,250,229,0.5);
        }
        .success-title { font-size: 1.25rem; font-weight: 700; color: var(--dark); margin-bottom: 8px; }
        .success-desc  { font-size: 0.875rem; color: var(--secondary); line-height: 1.6; margin-bottom: 18px; }

        /* Buttons */
        .btn-action-login {
            background: linear-gradient(135deg, var(--primary), #059669);
            color: #fff;
        }
        .btn-action-login:hover:not(:disabled) {
            background: linear-gradient(135deg, #065f46, var(--primary));
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(4,120,87,0.3);
        }
        .btn-action-login:disabled { opacity: 0.65; cursor: not-allowed; transform: none; box-shadow: none; }
        .btn-full { width: 100%; display: block; }

        /* Responsive */
        @media (max-width: 480px) {
            .login-body { padding: 16px; align-items: flex-start; padding-top: 40px; }
            .login-card { padding: 28px 18px; }
        }
    </style>
</head>
<body class="login-body">

    <div class="login-card" style="max-width: 440px;">

        <!-- Back link -->
        <a href="/login" class="back-to-login">
            <i class="fas fa-arrow-left"></i> Kembali ke Login
        </a>

        <!-- Header (konsisten dengan login/register) -->
        <div class="auth-icon-wrapper">
            <img src="/img/logo-banten.png" alt="Logo Banten" style="width: 100%; height: auto;">
        </div>
        <h2 class="auth-title">UPTD Pengujian</h2>
        <p class="auth-subtitle">Bahan Konstruksi Bangunan &amp; Informasi Konstruksi</p>

        <!-- ── TOKEN ERROR STATE ── -->
        <div class="token-error-state" id="tokenErrorState">
            <div class="error-icon-wrap">
                <i class="fas fa-link-slash"></i>
            </div>
            <p class="error-title">Link Tidak Valid</p>
            <p class="error-desc">Link reset password ini tidak valid atau sudah kedaluwarsa. Link hanya berlaku selama <strong>1 jam</strong> setelah dikirim.</p>
            <a href="/forgot-password" class="btn-auth-base btn-action-login btn-full" style="text-align:center; display:block;">
                <i class="fas fa-redo" style="margin-right:6px;"></i>Minta Link Baru
            </a>
        </div>

        <!-- ── FORM STATE ── -->
        <div id="formState">
            <h3 style="font-size:1.05rem; font-weight:700; color:var(--dark); margin-bottom:6px; text-align:left;">Buat Password Baru</h3>
            <p class="fp-desc">Masukkan password baru yang kuat untuk mengamankan akun Anda.</p>

            <!-- Alert container -->
            <div id="alertContainer"></div>

            <form id="resetPasswordForm" novalidate>
                <input type="hidden" id="token" value="<%= token %>">

                <!-- Password Baru -->
                <div class="form-group">
                    <label class="form-label" for="new_password">Password Baru</label>
                    <div class="input-wrapper has-icon-end">
                        <i class="fas fa-lock icon-start"></i>
                        <input
                            type="password"
                            id="new_password"
                            class="form-input"
                            placeholder="Minimal 8 karakter + 1 angka"
                            autocomplete="new-password"
                            required
                        >
                        <i class="fas fa-eye-slash icon-end" id="toggleNew" style="cursor:pointer;"></i>
                    </div>
                    <span class="field-error-msg" id="newPassError"></span>
                    <!-- Strength indicator -->
                    <div class="strength-wrap" id="strengthWrap">
                        <div class="strength-bars">
                            <span id="b1"></span><span id="b2"></span>
                            <span id="b3"></span><span id="b4"></span>
                        </div>
                        <span class="strength-label" id="strengthLabel">Masukkan password</span>
                    </div>
                </div>

                <!-- Konfirmasi Password -->
                <div class="form-group">
                    <label class="form-label" for="confirm_password">Konfirmasi Password</label>
                    <div class="input-wrapper has-icon-end">
                        <i class="fas fa-lock icon-start"></i>
                        <input
                            type="password"
                            id="confirm_password"
                            class="form-input"
                            placeholder="Ketik ulang password baru"
                            autocomplete="new-password"
                            required
                        >
                        <i class="fas fa-eye-slash icon-end" id="toggleConfirm" style="cursor:pointer;"></i>
                    </div>
                    <span class="field-error-msg" id="confirmPassError"></span>
                </div>

                <button type="submit" class="btn-auth-base btn-action-login btn-full" id="btnSubmit">
                    <span class="button-text"><i class="fas fa-shield-alt" style="margin-right:6px;"></i>Simpan Password Baru</span>
                    <span class="button-loader" style="display:none;"><i class="fas fa-spinner fa-spin"></i> Menyimpan...</span>
                </button>
            </form>
        </div>

        <!-- ── SUCCESS STATE ── -->
        <div class="success-state" id="successState">
            <div class="success-icon">
                <i class="fas fa-check-double"></i>
            </div>
            <p class="success-title">Password Berhasil Direset!</p>
            <p class="success-desc">Password baru Anda telah tersimpan. Anda akan diarahkan ke halaman login dalam beberapa detik.</p>
            <div class="alert-box alert-success" style="text-align:left;">
                <i class="fas fa-check-circle"></i>
                <span>Silakan login menggunakan password baru Anda.</span>
            </div>
            <a href="/login" class="btn-auth-base btn-action-login btn-full" style="text-align:center; display:block;">
                <i class="fas fa-sign-in-alt" style="margin-right:6px;"></i>Login Sekarang
            </a>
        </div>

        <!-- Footer -->
        <div class="auth-footer">
            © 2026 Pengujian Bahan Konstruksi Bangunan &amp; Informasi Konstruksi Provinsi Banten.
        </div>

    </div>

    <script>
        // ── Cek token ────────────────────────────────────────────────────────
        const tokenVal = document.getElementById('token')?.value;
        if (!tokenVal || tokenVal.trim() === '' || tokenVal === 'undefined') {
            document.getElementById('formState').style.display = 'none';
            document.getElementById('tokenErrorState').style.display = 'block';
        }

        // ── Toggle password visibility ─────────────────────────────────────
        function setupToggle(iconId, inputId) {
            const icon  = document.getElementById(iconId);
            const input = document.getElementById(inputId);
            if (!icon || !input) return;
            icon.addEventListener('click', () => {
                const isPass = input.type === 'password';
                input.type = isPass ? 'text' : 'password';
                icon.classList.toggle('fa-eye-slash', !isPass);
                icon.classList.toggle('fa-eye', isPass);
            });
        }
        setupToggle('toggleNew', 'new_password');
        setupToggle('toggleConfirm', 'confirm_password');

        // ── Password strength ──────────────────────────────────────────────
        const newPassInput     = document.getElementById('new_password');
        const confirmPassInput = document.getElementById('confirm_password');
        const strengthWrap     = document.getElementById('strengthWrap');
        const strengthLabel    = document.getElementById('strengthLabel');
        const bars             = ['b1','b2','b3','b4'].map(id => document.getElementById(id));
        const newPassError     = document.getElementById('newPassError');
        const confirmPassError = document.getElementById('confirmPassError');

        function calcStrength(pw) {
            let s = 0;
            if (pw.length >= 8)  s++;
            if (pw.length >= 12) s++;
            if (/[A-Z]/.test(pw) && /[a-z]/.test(pw)) s++;
            if (/\d/.test(pw))   s++;
            if (/[^A-Za-z0-9]/.test(pw)) s++;
            return Math.min(s, 4);
        }

        function renderStrength(score) {
            const names  = ['', 'Lemah', 'Cukup', 'Kuat', 'Sangat Kuat'];
            const cls    = ['', 'weak', 'medium', 'strong', 'strong'];
            const barCls = ['', 's-weak', 's-medium', 's-strong', 's-strong'];
            bars.forEach((b, i) => { b.className = i < score ? barCls[score] : ''; });
            strengthLabel.textContent = score > 0 ? names[score] : 'Masukkan password';
            strengthLabel.className   = 'strength-label ' + (score > 0 ? cls[score] : '');
        }

        newPassInput.addEventListener('input', () => {
            const v = newPassInput.value;
            strengthWrap.style.display = v.length > 0 ? 'block' : 'none';
            if (v.length > 0) renderStrength(calcStrength(v));
            if (newPassInput.classList.contains('is-invalid')) validateNewPass();
            if (confirmPassInput.value && confirmPassInput.classList.contains('is-invalid')) validateConfirmPass();
        });
        confirmPassInput.addEventListener('input', () => {
            if (confirmPassInput.classList.contains('is-invalid')) validateConfirmPass();
        });

        // ── Validation helpers ─────────────────────────────────────────────
        function setError(input, el, msg) {
            input.classList.add('is-invalid'); input.classList.remove('is-valid');
            el.textContent = msg; el.classList.add('show');
        }
        function clearErr(input, el) {
            input.classList.remove('is-invalid'); input.classList.add('is-valid');
            el.classList.remove('show');
        }

        function validateNewPass() {
            const v = newPassInput.value;
            if (!v)            { setError(newPassInput, newPassError, 'Password tidak boleh kosong.'); return false; }
            if (v.length < 8)  { setError(newPassInput, newPassError, 'Password minimal 8 karakter.'); return false; }
            if (!/\d/.test(v)) { setError(newPassInput, newPassError, 'Password harus mengandung minimal 1 angka.'); return false; }
            clearErr(newPassInput, newPassError);
            return true;
        }
        function validateConfirmPass() {
            const v = confirmPassInput.value;
            if (!v)                        { setError(confirmPassInput, confirmPassError, 'Konfirmasi password tidak boleh kosong.'); return false; }
            if (v !== newPassInput.value)  { setError(confirmPassInput, confirmPassError, 'Password dan konfirmasi tidak cocok.'); return false; }
            clearErr(confirmPassInput, confirmPassError);
            return true;
        }

        // ── Alert ──────────────────────────────────────────────────────────
        function showAlert(type, iconClass, msg) {
            document.getElementById('alertContainer').innerHTML = `
                <div class="alert-box alert-${type}">
                    <i class="fas ${iconClass}"></i>
                    <span>${msg}</span>
                </div>`;
        }

        // ── Submit ─────────────────────────────────────────────────────────
        document.getElementById('resetPasswordForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!validateNewPass() | !validateConfirmPass()) return; // bitwise so both run

            const btn     = document.getElementById('btnSubmit');
            const btnText = btn.querySelector('.button-text');
            const btnLoad = btn.querySelector('.button-loader');
            const token   = document.getElementById('token').value;

            btnText.style.display = 'none';
            btnLoad.style.display = 'inline';
            btn.disabled = true;
            document.getElementById('alertContainer').innerHTML = '';

            try {
                const backendUrl = (window.APP_CONFIG?.backendUrl || 'http://localhost:5000');
                const res  = await fetch(backendUrl + '/api/auth/reset-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token, new_password: newPassInput.value })
                });
                const data = await res.json();

                if (data.success) {
                    document.getElementById('formState').style.display = 'none';
                    document.getElementById('successState').style.display = 'block';
                    setTimeout(() => { window.location.href = '/login'; }, 3000);
                } else {
                    // Token expired / invalid
                    if (res.status === 400 && (data.message || '').includes('kedaluwarsa')) {
                        document.getElementById('formState').style.display = 'none';
                        document.getElementById('tokenErrorState').style.display = 'block';
                    } else {
                        showAlert('error', 'fa-exclamation-circle', data.message || 'Gagal menyimpan password.');
                        btnText.style.display = 'inline';
                        btnLoad.style.display = 'none';
                        btn.disabled = false;
                    }
                }
            } catch (err) {
                showAlert('error', 'fa-wifi', 'Gagal terhubung ke server. Periksa koneksi internet Anda.');
                btnText.style.display = 'inline';
                btnLoad.style.display = 'none';
                btn.disabled = false;
            }
        });
    </script>

</body>
</html>
